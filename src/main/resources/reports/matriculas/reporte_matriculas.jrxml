	<parameter name="LOGO" class="java.io.InputStream" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
    m.id,
    m.fecha,
    m.estado,

    a.codigo,
    CONCAT(a.nombres,' ',a.apellidos) alumno,

    c.nombre curso,
    dm.ciclo,
    dm.nota

FROM matricula m

INNER JOIN alumno a
ON m.alumno_id = a.id

INNER JOIN detalle_matricula dm
ON m.id = dm.matricula_id

INNER JOIN curso c
ON dm.curso_id = c.id

ORDER BY m.id]]>
	</queryString>
