	<parameter name="LOGO" class="java.io.InputStream" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
    n.id,
    n.fecha_registro,
    n.nota,

    a.codigo,
    a.nombres,
    a.apellidos,

    c.nombre AS curso,

    d.nombres AS docente_nombres,
    d.apellidos AS docente_apellidos

FROM nota n

INNER JOIN alumno a
    ON n.alumno_id = a.id

INNER JOIN curso c
    ON n.curso_id = c.id

INNER JOIN docente d
    ON n.docente_id = d.id

ORDER BY a.apellidos, a.nombres]]>
	</queryString>
